{
  "name": "torch",
  "version": "3.2.0",
  "description": "Torch HUD Controls",
  "main": "src/torch.js",

  "scripts": {
    "lint": "eslint .",
    "copy-dist": "npm-run-all copy:dist*",
    "copy:dist1": "npx cpy ./torch.css dist/",
    "copy:dist3": "npx cpy ./lang/ dist/",
    "copy:dist4": "npx cpy ./module.json dist/",
    "copy:dist5": "npx cpy ./README.md dist/",
    "build": "npm-run-all build:prod copy-dist",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --config-node-env=production",
    "test": "npm-run-all lint build:dev test:units",
    "test:units": "mocha",
    "cover": "c8 --reporter html mocha",
    "watch": "webpack --mode development --watch",
    "serve": "webpack serve"
  },
  "keywords": [],
  "contributors": [
    {
      "name": "Deuce",
      "flags": {}
    },
    {
      "name": "Lupestro",
      "email": "lupestro@macksoft.com",
      "flags": {}
    }
  ],
  "license": "SEE LICENSE IN README.md",
  "dependencies": {
    "ajv":"^8.18.0",
    "json5":"^2.2.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-syntax-dynamic-import":"^7.8.3", 
    "babel-loader": "^10.1.1",
    "babel-preset-es2015": "^6.24.1",
    "c8":"^11.0.0",
    "cpy-cli":"^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "npm-run-all":"^4.1.5",
    "mini-css-extract-plugin":"^2.10.2",
    "mocha":"^11.7.5",
    "prettier": "^3.8.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
